{
  "name": "sonilo",
  "version": "0.1.0",
  "description": "Official TypeScript/JavaScript client for the Sonilo API",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sonilo-ai/sonilo-js.git"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "lint": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "keywords": [
    "sonilo",
    "music",
    "generation",
    "text-to-music",
    "video-to-music",
    "ai"
  ]
}
