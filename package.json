{
  "name": "sonilo-video-kit",
  "version": "0.1.0",
  "description": "Video helpers for the Sonilo API: generate a soundtrack and mix it into your video with ffmpeg",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sonilo-ai/sonilo-video-kit.git"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "prepack": "npm run build"
  },
  "dependencies": {
    "sonilo": "file:../sonilo-js"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "keywords": [
    "sonilo",
    "video",
    "music",
    "soundtrack",
    "ffmpeg",
    "mix",
    "ai"
  ]
}
